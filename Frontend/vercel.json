{
  "rewrites": [
    {
      "source": "/api/redirect",
      "destination": "/api/redirect.js"
    },
    {
      "source": "/r/:code",
      "destination": "/api/redirect?code=:code"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        }
      ]
    }
  ]
}
